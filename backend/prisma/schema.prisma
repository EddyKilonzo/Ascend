generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

enum HabitFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum HabitCategory {
  HEALTH
  FITNESS
  LEARNING
  CAREER
  FINANCE
  RELATIONSHIPS
  SPIRITUAL
  CUSTOM
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum GoalTimeframe {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum FocusMode {
  POMODORO_25
  DEEP_WORK_50
  ULTRA_FOCUS_90
}

enum FocusStatus {
  ACTIVE
  COMPLETED
  INTERRUPTED
}

enum SkillCategory {
  DISCIPLINE
  FOCUS
  FITNESS
  LEARNING
  CAREER
  FINANCE
  SOCIAL
  HEALTH
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  SEASONAL
}

enum NotificationType {
  HABIT_REMINDER
  TASK_REMINDER
  GOAL_UPDATE
  STREAK_ALERT
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
  CHALLENGE_UPDATE
  MAYA_SUGGESTION
  SYSTEM
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  X
  REDDIT
  OTHER
}

enum CommitmentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  EMAIL_VERIFY
  TWO_FA_ENABLE
  TWO_FA_DISABLE
}

enum UploadContext {
  AVATAR
  GOAL_MOTIVATION
  HABIT_EVIDENCE
  GENERAL
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  username          String        @unique
  displayName       String?
  avatarUrl         String?
  bio               String?
  timezone          String        @default("UTC")
  role              Role          @default(USER)
  isActive          Boolean       @default(true)
  isEmailVerified   Boolean       @default(false)
  isTwoFaEnabled    Boolean       @default(false)
  twoFaSecret       String?

  // Brute-force protection — locked after 10 consecutive failed logins
  failedLoginAttempts Int        @default(0)
  lockUntil         DateTime?

  // Preferences stored as JSON
  notificationPrefs Json          @default("{}")
  themePrefs        Json          @default("{}")
  productivityPrefs Json          @default("{}")

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  authProviders     UserAuthProvider[]
  sessions          Session[]
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]

  habits            Habit[]
  habitLogs         HabitLog[]
  plannerTasks      PlannerTask[]
  calendarEvents    CalendarEvent[]
  calendarIntegrations CalendarIntegration[]
  goals             Goal[]
  focusSessions     FocusSession[]

  xpLogs            XpLog[]
  level             UserLevel?
  skillProgress     UserSkillProgress[]

  userAchievements  UserAchievement[]
  userBadges        UserBadge[]
  challengeProgress UserChallengeProgress[]

  commitments       Commitment[]
  socialUsageLogs   SocialUsageLog[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  dashboardSnapshot UserDashboardSnapshot?
  analyticsDaily    AnalyticsDaily[]
  analyticsWeekly   AnalyticsWeekly[]
  analyticsMonthly  AnalyticsMonthly[]
  statistics        UserStatistics?
  userFiles         UserFile[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model UserAuthProvider {
  id           String       @id @default(uuid())
  userId       String
  provider     AuthProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("user_auth_providers")
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  // Stored as bcrypt hash — never the raw token
  refreshTokenHash  String   @unique
  userAgent         String?
  ipAddress         String?
  isRevoked         Boolean  @default(false)
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verifications")
}

// ─── Habits ───────────────────────────────────────────────────────────────────

model Habit {
  id            String         @id @default(uuid())
  userId        String
  name          String
  description   String?
  category      HabitCategory  @default(CUSTOM)
  frequency     HabitFrequency @default(DAILY)
  targetCount   Int            @default(1)
  color         String?
  icon          String?
  reminderTime  String?
  isActive      Boolean        @default(true)
  order         Int            @default(0)
  xpReward      Int            @default(10)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          HabitLog[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([frequency])
  @@map("habits")
}

model HabitLog {
  id          String   @id @default(uuid())
  habitId     String
  userId      String
  completedAt DateTime @default(now())
  count       Int      @default(1)
  note        String?
  streak      Int      @default(0)
  xpEarned    Int      @default(0)
  createdAt   DateTime @default(now())

  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId, completedAt])
  @@index([habitId])
  @@index([userId])
  @@index([completedAt])
  @@index([userId, completedAt])
  @@index([habitId, completedAt])
  @@map("habit_logs")
}

// ─── Planner ──────────────────────────────────────────────────────────────────

model PlannerTask {
  id            String      @id @default(uuid())
  userId        String
  title         String
  description   String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus  @default(TODO)
  scheduledDate DateTime?
  scheduledTime String?
  dueDate       DateTime?
  duration      Int?
  isTimeBlocked Boolean     @default(false)
  blockStart    String?
  blockEnd      String?
  isRecurring   Boolean     @default(false)
  recurrenceRule String?
  goalId        String?
  xpReward      Int         @default(5)
  order         Int         @default(0)
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal          Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, scheduledDate])
  @@index([userId, status])
  @@index([dueDate])
  @@map("planner_tasks")
}

// ─── Calendar ─────────────────────────────────────────────────────────────────

model CalendarEvent {
  id              String    @id @default(uuid())
  userId          String
  externalId      String?
  title           String
  description     String?
  location        String?
  startTime       DateTime
  endTime         DateTime
  isAllDay        Boolean   @default(false)
  color           String?
  isImported      Boolean   @default(false)
  source          String?
  recurrenceRule  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId])
  @@index([userId])
  @@index([userId, startTime])
  @@map("calendar_events")
}

model CalendarIntegration {
  id              String    @id @default(uuid())
  userId          String    @unique
  provider        String
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  calendarId      String?
  lastSyncedAt    DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("calendar_integrations")
}

// ─── Goals ────────────────────────────────────────────────────────────────────

model Goal {
  id           String        @id @default(uuid())
  userId       String
  title        String
  description  String?
  timeframe    GoalTimeframe @default(SHORT_TERM)
  status       GoalStatus    @default(ACTIVE)
  targetDate   DateTime?
  progress     Float         @default(0)
  color        String?
  icon         String?
  xpReward     Int           @default(100)
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones   GoalMilestone[]
  progressLogs GoalProgressLog[]
  tasks        PlannerTask[]

  @@index([userId])
  @@index([userId, status])
  @@map("goals")
}

model GoalMilestone {
  id          String   @id @default(uuid())
  goalId      String
  title       String
  description String?
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_milestones")
}

model GoalProgressLog {
  id        String   @id @default(uuid())
  goalId    String
  progress  Float
  note      String?
  loggedAt  DateTime @default(now())

  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([loggedAt])
  @@map("goal_progress_logs")
}

// ─── Focus ────────────────────────────────────────────────────────────────────

model FocusSession {
  id            String      @id @default(uuid())
  userId        String
  mode          FocusMode   @default(POMODORO_25)
  status        FocusStatus @default(ACTIVE)
  plannedMinutes Int
  actualMinutes Int?
  interruptions Int         @default(0)
  taskId        String?
  note          String?
  xpEarned      Int         @default(0)
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startedAt])
  @@index([status])
  @@map("focus_sessions")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model XpLog {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  source      String
  sourceId    String?
  description String?
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, earnedAt])
  @@map("xp_logs")
}

model UserLevel {
  id            String   @id @default(uuid())
  userId        String   @unique
  level         Int      @default(1)
  currentXp     Int      @default(0)
  totalXp       Int      @default(0)
  xpToNextLevel Int      @default(100)
  prestige      Int      @default(0)
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@index([totalXp])
  @@map("user_levels")
}

model Skill {
  id          String        @id @default(uuid())
  name        String        @unique
  category    SkillCategory
  description String?
  icon        String?
  maxLevel    Int           @default(100)
  createdAt   DateTime      @default(now())

  userProgress UserSkillProgress[]

  @@map("skills")
}

model UserSkillProgress {
  id        String   @id @default(uuid())
  userId    String
  skillId   String
  level     Int      @default(1)
  xp        Int      @default(0)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@map("user_skill_progress")
}

model Achievement {
  id          String            @id @default(uuid())
  slug        String            @unique
  name        String
  description String
  icon        String?
  badgeUrl    String?
  rarity      AchievementRarity @default(COMMON)
  xpReward    Int               @default(50)
  criteria    Json
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())

  userAchievements UserAchievement[]

  @@index([slug])
  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  notified      Boolean     @default(false)

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Badge {
  id          String            @id @default(uuid())
  slug        String            @unique
  name        String
  description String?
  imageUrl    String?
  rarity      AchievementRarity @default(COMMON)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  badgeId    String
  earnedAt   DateTime @default(now())
  isDisplayed Boolean @default(false)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model Challenge {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  description String?
  type        ChallengeType @default(DAILY)
  xpReward    Int           @default(25)
  criteria    Json
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  userProgress UserChallengeProgress[]

  @@index([type])
  @@index([startsAt, endsAt])
  @@map("challenges")
}

model UserChallengeProgress {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  progress    Float     @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("user_challenge_progress")
}

// ─── Accountability ───────────────────────────────────────────────────────────

model Commitment {
  id           String           @id @default(uuid())
  userId       String
  title        String
  description  String?
  dueAt        DateTime
  status       CommitmentStatus @default(PENDING)
  completedAt  DateTime?
  failedAt     DateTime?
  failureNote  String?
  xpStake      Int              @default(20)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([dueAt])
  @@map("commitments")
}

// ─── Social Tracking ──────────────────────────────────────────────────────────

model SocialUsageLog {
  id          String         @id @default(uuid())
  userId      String
  platform    SocialPlatform
  minutes     Int
  loggedDate  DateTime
  weekNumber  Int
  year        Int
  createdAt   DateTime       @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, loggedDate])
  @@index([userId])
  @@index([userId, platform])
  @@index([loggedDate])
  @@map("social_usage_logs")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entity     String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Dashboard Snapshot (performance read model) ──────────────────────────────

model UserDashboardSnapshot {
  id                    String   @id @default(uuid())
  userId                String   @unique
  level                 Int      @default(1)
  currentXp             Int      @default(0)
  totalXp               Int      @default(0)
  xpToNextLevel         Int      @default(100)
  currentStreak         Int      @default(0)
  longestStreak         Int      @default(0)
  productivityScore     Float    @default(0)
  focusScore            Float    @default(0)
  consistencyScore      Float    @default(0)
  accountabilityScore   Float    @default(0)
  habitsCompletedToday  Int      @default(0)
  totalHabitsToday      Int      @default(0)
  focusMinutesToday     Int      @default(0)
  tasksCompletedToday   Int      @default(0)
  activeGoals           Int      @default(0)
  completedGoals        Int      @default(0)
  totalAchievements     Int      @default(0)
  weeklyXp              Int      @default(0)
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productivityScore])
  @@index([totalXp])
  @@map("user_dashboard_snapshots")
}

// ─── Pre-computed Analytics (read models) ─────────────────────────────────────

model AnalyticsDaily {
  id                   String   @id @default(uuid())
  userId               String
  date                 DateTime
  habitsCompleted      Int      @default(0)
  habitTotal           Int      @default(0)
  habitCompletionRate  Float    @default(0)
  focusMinutes         Int      @default(0)
  focusSessions        Int      @default(0)
  tasksCompleted       Int      @default(0)
  tasksCreated         Int      @default(0)
  xpEarned             Int      @default(0)
  productivityScore    Float    @default(0)
  socialMinutes        Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
  @@map("analytics_daily")
}

model AnalyticsWeekly {
  id                   String   @id @default(uuid())
  userId               String
  weekStart            DateTime
  weekNumber           Int
  year                 Int
  habitsCompleted      Int      @default(0)
  avgHabitRate         Float    @default(0)
  totalFocusMinutes    Int      @default(0)
  focusSessions        Int      @default(0)
  tasksCompleted       Int      @default(0)
  xpEarned             Int      @default(0)
  avgProductivityScore Float    @default(0)
  peakDay              String?
  bestStreak           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber, year])
  @@index([userId, year, weekNumber])
  @@map("analytics_weekly")
}

model AnalyticsMonthly {
  id                   String   @id @default(uuid())
  userId               String
  month                Int
  year                 Int
  habitsCompleted      Int      @default(0)
  avgHabitRate         Float    @default(0)
  totalFocusMinutes    Int      @default(0)
  focusSessions        Int      @default(0)
  tasksCompleted       Int      @default(0)
  goalsCompleted       Int      @default(0)
  xpEarned             Int      @default(0)
  avgProductivityScore Float    @default(0)
  topSkill             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId, year, month])
  @@map("analytics_monthly")
}

// ─── User Files (Cloudinary upload metadata) ─────────────────────────────────

model UserFile {
  id        String        @id @default(uuid())
  userId    String
  url       String
  publicId  String        @unique
  context   UploadContext
  contextId String?
  filename  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, context])
  @@index([contextId])
  @@map("user_files")
}

// ─── User Statistics Aggregates (write-through cache) ─────────────────────────

model UserStatistics {
  id                 String   @id @default(uuid())
  userId             String   @unique
  totalHabits        Int      @default(0)
  activeHabits       Int      @default(0)
  totalHabitLogs     Int      @default(0)
  longestStreak      Int      @default(0)
  currentStreak      Int      @default(0)
  totalFocusMinutes  Int      @default(0)
  totalFocusSessions Int      @default(0)
  totalTasksCreated  Int      @default(0)
  totalTasksDone     Int      @default(0)
  totalGoals         Int      @default(0)
  completedGoals     Int      @default(0)
  totalCommitments   Int      @default(0)
  keptCommitments    Int      @default(0)
  trustScore         Float    @default(100)
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trustScore])
  @@map("user_statistics")
}
